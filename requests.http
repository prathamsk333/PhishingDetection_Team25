###############################################################################
# 8. Generate Test Data - Random
###############################################################################

GET http://localhost:8000/generate_test_data?type=random&count=1
Accept: application/json

###############################################################################
# 9. Generate Test Data - Phishing Profile (Suspicious)
###############################################################################

GET http://localhost:8000/generate_test_data?type=phishing&count=3
Accept: application/json

###############################################################################
# 10. Generate Test Data - Legitimate Profile (Safe)
###############################################################################

GET http://localhost:8000/generate_test_data?type=legitimate&count=5
Accept: application/json

###############################################################################
# 11. VERIFICATION: Extracted extreme profiles (batch)
#     Expected: first record → 0 (phishing), second record → 1 (legitimate)
###############################################################################

POST http://localhost:8000/predict_json
Content-Type: application/json
Accept: application/json

[
  {
    "having_IP_Address": -1,
    "URL_Length": -1,
